# PostgreSQL (TimescaleDB)
POSTGRES_USER=whoop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=health
POSTGRES_URL=postgresql+asyncpg://whoop:changeme@postgres:5432/health

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama Cloud — get key at https://ollama.com/settings/keys
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE=https://ollama.com
# Cloud models require the -cloud suffix: https://ollama.com/search?c=cloud
OLLAMA_MODEL=deepseek-v3.1:671b-cloud
OLLAMA_SNAPSHOT_MODEL=deepseek-v3.1:671b-cloud

# Signal bot (dedicated number, NOT your personal number)
SIGNAL_BOT_NUMBER=+1XXXXXXXXXX
# Your personal Signal number — the agent will only respond to this
SIGNAL_USER_NUMBER=+1XXXXXXXXXX
SIGNAL_API_URL=http://signal-rest:8080

# Shared secret used by the Expo app when posting metrics
SERVER_SECRET=replace_with_random_hex_32_chars
